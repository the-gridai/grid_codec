# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
grid_codec-*.tar

# Temporary files, for example, from tests.
/tmp/

# Coverage and profiling artifacts
/artifacts/

# Profiling output files
*.dis
perf.data
perf.data.*
callgrind.out.*
coverage_output.txt

# Cursor IDE config
.cursor/*
!.cursor/skills/
!.cursor/skills/**

# Example app build artifacts
/example_app/_build/
/example_app/deps/
/example_app/cover/

.DS_Store

# Elixir 1.20 upgrade experiment artifacts (keep markdown/scripts only)
/docs/elixir-1.20-upgrade/**/_build/
/docs/elixir-1.20-upgrade/**/*.log
