# Schema for grid_file_test.exs - unique IDs to avoid collisions

schema GridFileTest {
  id: 7000
  version: 1
}

struct Order (template_id: 7001) {
  id: uuid_string
  user_id: u64
  symbol: string16
  quantity: u32
  active: bool
}

struct Trade (template_id: 7002) {
  trade_id: uuid_string
  order_id: uuid_string
  price: u64
  quantity: u32
}
