{
  "name": "vscode-grid",
  "displayName": "GridCodec Schema Language",
  "description": "Syntax highlighting for .grid schema definition files",
  "version": "0.1.0",
  "publisher": "spectral-finance",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-gridai/grid_codec"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "grid",
        "aliases": [
          "GridCodec Schema",
          "grid"
        ],
        "extensions": [
          ".grid"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "grid",
        "scopeName": "source.grid",
        "path": "./syntaxes/grid.tmLanguage.json"
      }
    ]
  }
}
