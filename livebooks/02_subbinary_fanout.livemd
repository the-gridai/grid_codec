## Setup: Define Test Codec

```elixir
defmodule Demo.OrderEvent do
  use GridCodec

  defcodec do
    field(:order_id, :uuid)
    field(:client_order_id, :uuid)
    field(:user_id, :u64)
    field(:account_id, :u64)
    field(:price, :u64)
    field(:quantity, :u32)
    field(:filled_qty, :u32)
    field(:side, :u8)
    field(:order_type, :u8)
    field(:time_in_force, :u8)
    field(:timestamp, :timestamp_us)
    field(:flags, :u8)
  end
end

order = %{
  order_id: :crypto.strong_rand_bytes(16),
  client_order_id: :crypto.strong_rand_bytes(16),
  user_id: 12_345_678_901_234_567,
  account_id: 98_765_432_109_876_543,
  price: 15_000_000_000,
  quantity: 100_000,
  filled_qty: 0,
  side: 1,
  order_type: 2,
  time_in_force: 1,
  timestamp: System.system_time(:microsecond),
  flags: 7
}

binary = Demo.OrderEvent.encode(order)

IO.puts("Encoded size: #{byte_size(binary)} bytes")
IO.puts("Binary type: #{if byte_size(binary) > 64, do: "refc (shared)", else: "heap (copied)"}")
```

## Sub-Binary Field Access

GridCodec can read fields directly from the binary without decoding everything:

```elixir
envelope = Demo.OrderEvent.wrap(binary)

IO.puts("═══ Sub-Binary Field Access Demo ═══\n")

fields = [:order_id, :client_order_id, :user_id, :price, :quantity, :side, :timestamp, :flags]

for field <- fields do
  value = Demo.OrderEvent.get(envelope, field)
  
  display = case field do
    f when f in [:order_id, :client_order_id] and is_binary(value) -> 
      String.slice(Base.encode16(value, case: :lower), 0, 12) <> "..."
    _ -> 
      inspect(value)
  end
  
  IO.puts("  #{String.pad_trailing(to_string(field), 16)} = #{display}")
end

IO.puts("\nAll accesses are O(1) - constant time regardless of field position!")
```

## Benchmark: Sub-Binary Access vs Full Decode

```elixir
# Create map (the baseline - fastest possible access)
map_data = %{
  order_id: order.order_id,
  client_order_id: order.client_order_id,
  user_id: order.user_id,
  price: order.price,
  quantity: order.quantity,
  side: order.side,
  timestamp: order.timestamp,
  flags: order.flags
}

# JSON version for comparison
json_data = %{
  "order_id" => Base.encode64(order.order_id),
  "client_order_id" => Base.encode64(order.client_order_id),
  "user_id" => order.user_id,
  "price" => order.price,
  "quantity" => order.quantity,
  "side" => order.side,
  "timestamp" => order.timestamp,
  "flags" => order.flags
}
json_binary = Jason.encode!(json_data)

results = Benchee.run(
  %{
    "Map: direct access" => fn -> map_data.price end,
    "GridCodec: get(:price)" => fn -> Demo.OrderEvent.get(envelope, :price) end,
    "GridCodec: get(:flags)" => fn -> Demo.OrderEvent.get(envelope, :flags) end,
    "GridCodec: full decode" => fn ->
      {:ok, decoded} = Demo.OrderEvent.decode(binary)
      decoded.price
    end,
    "JSON: full decode" => fn ->
      decoded = Jason.decode!(json_binary)
      decoded["price"]
    end
  },
  time: 2,
  warmup: 1,
  print: [configuration: false, benchmarking: false]
)

perf_data =
  results.scenarios
  |> Enum.map(fn s ->
    %{
      "Method" => s.name,
      "Million ops/s" => Float.round(s.run_time_data.statistics.ips / 1_000_000, 2),
      "Median (ns)" => Float.round(s.run_time_data.statistics.median, 1)
    }
  end)
  |> Enum.sort_by(& &1["Million ops/s"], :desc)

Kino.DataTable.new(perf_data)
```

```elixir
Vl.new(width: 600, height: 300, title: "Field Access Speed Comparison")
|> Vl.data_from_values(perf_data)
|> Vl.mark(:bar, corner_radius_end: 4)
|> Vl.encode_field(:y, "Method", type: :nominal, sort: "-x", axis: [title: nil])
|> Vl.encode_field(:x, "Million ops/s", type: :quantitative, title: "Million ops/second")
|> Vl.encode_field(:color, "Method", type: :nominal, legend: nil, scale: [scheme: "set2"])
```

**Observations:**

* **Map direct access** is the baseline - pure in-memory lookup, no serialization overhead
* **GridCodec `get()`** approaches map speed while working on a binary (and that binary can be shared!)
* `get(:price)` and `get(:flags)` have nearly identical performance - that's O(1) access regardless of field position
* **Full decode** (GridCodec or JSON) is 7-10x slower than direct access

## Summary

### Direct Field Access

GridCodec reads individual fields directly from the binary using compile-time offset tables. This is O(1) regardless of field position.

### BEAM Binary Sharing (Refc Binaries)

Binaries >64 bytes are reference-counted. When sent between processes, only a reference is copied. This makes fan-out memory-efficient.

### The Pattern

Instead of: `receive → decode fully → route → maybe discard`

Do this: `receive → extract routing fields O(1) → route → decode only if needed`

### Requirements

* Schema must be known at compile time
* Both sender and receiver must have matching schema
* BEAM-only (no cross-language support)
